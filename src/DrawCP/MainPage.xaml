<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:graphics="clr-namespace:DrawCP.Graphics"
             x:Class="DrawCP.MainPage"
             Title="Lucifer Drawing Pro">

    <ContentPage.Resources>
        <Color x:Key="PrimaryDark">#1A1A1B</Color>
        <Color x:Key="AccentBlue">#007AFF</Color>
        <Color x:Key="SurfaceLight">#FFFFFF</Color>

        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="BackgroundColor" Value="Transparent"/>
            <Setter Property="TextColor" Value="#333333"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="HeightRequest" Value="40"/>
            <Setter Property="Padding" Value="5,0"/>
        </Style>

        <Style x:Key="GroupBorder" TargetType="Border">
            <Setter Property="Stroke" Value="#E0E0E0"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Setter Property="BackgroundColor" Value="White"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="StrokeShape" Value="RoundRectangle 12"/>
            <Setter Property="Shadow">
                <Setter.Value>
                    <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.05" />
                </Setter.Value>
            </Setter>
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, *" BackgroundColor="#F5F5F7">
        <Border Grid.Row="0" Margin="10" Style="{StaticResource GroupBorder}">
            <ScrollView Orientation="Vertical">
                <FlexLayout Wrap="Wrap" JustifyContent="Start" AlignItems="Center" Direction="Row">

                    <HorizontalStackLayout Spacing="2" Margin="5">
                        <Button Text="Select" Style="{StaticResource ToolBtn}" Clicked="OnToolSelected" CommandParameter="Select" WidthRequest="60"/>
                        <Button Text="Point" Style="{StaticResource ToolBtn}" Clicked="OnToolSelected" CommandParameter="Point" WidthRequest="55"/>
                        <Button Text="Line" Style="{StaticResource ToolBtn}" Clicked="OnToolSelected" CommandParameter="Line" WidthRequest="50"/>
                        <Button Text="Rect" Style="{StaticResource ToolBtn}" Clicked="OnToolSelected" CommandParameter="Rectangle" WidthRequest="50"/>
                        <Button Text="Square" Style="{StaticResource ToolBtn}" Clicked="OnToolSelected" CommandParameter="Square" WidthRequest="60"/>
                        <Button Text="Ellipse" Style="{StaticResource ToolBtn}" Clicked="OnToolSelected" CommandParameter="Ellipse" WidthRequest="60"/>
                        <Button Text="Circle" Style="{StaticResource ToolBtn}" Clicked="OnToolSelected" CommandParameter="Circle" WidthRequest="55"/>
                    </HorizontalStackLayout>

                    <BoxView WidthRequest="1" HeightRequest="30" BackgroundColor="#D1D1D6" Margin="5"/>

                    <HorizontalStackLayout Spacing="2" Margin="5">
                        <Button Text="Fill" Style="{StaticResource ToolBtn}" Clicked="OnFillShape" TextColor="#FF9500" WidthRequest="45"/>
                        <Button Text="Undo" Style="{StaticResource ToolBtn}" Clicked="OnUndo" TextColor="#5856D6" WidthRequest="55"/>
                        <Button Text="Del" Style="{StaticResource ToolBtn}" Clicked="OnDelete" TextColor="#FF3B30" WidthRequest="45"/>
                    </HorizontalStackLayout>

                    <BoxView WidthRequest="1" HeightRequest="30" BackgroundColor="#D1D1D6" Margin="5"/>

                    <HorizontalStackLayout Spacing="5" Margin="5">
                        <Slider x:Name="ThicknessSlider" Minimum="1" Maximum="20" Value="2" WidthRequest="80" ValueChanged="OnThicknessChanged"/>
                        <Border StrokeShape="RoundRectangle 15" HeightRequest="30" WidthRequest="30">
                            <BoxView x:Name="ColorPreview" Color="Black">
                                <BoxView.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnColorPickerTapped"/>
                                </BoxView.GestureRecognizers>
                            </BoxView>
                        </Border>
                    </HorizontalStackLayout>

                    <BoxView WidthRequest="1" HeightRequest="30" BackgroundColor="#D1D1D6" Margin="5"/>

                    <HorizontalStackLayout Spacing="2" Margin="5">
                        <Button Text="In" Style="{StaticResource ToolBtn}" Clicked="OnLoadBinary" WidthRequest="40"/>
                        <Button Text="Save" Style="{StaticResource ToolBtn}" Clicked="OnSaveBinary" BackgroundColor="#34C759" TextColor="White" WidthRequest="55"/>
                        <Button Text="PNG" Style="{StaticResource ToolBtn}" Clicked="OnExportImage" BackgroundColor="{StaticResource PrimaryDark}" TextColor="White" WidthRequest="55"/>
                    </HorizontalStackLayout>

                </FlexLayout>
            </ScrollView>
        </Border>

        <Grid Grid.Row="1" Margin="10" BackgroundColor="White" IsClippedToBounds="True">
            <ContentView x:Name="CanvasContainer" HorizontalOptions="Start" VerticalOptions="Start" AnchorX="0" AnchorY="0">
                <ContentView.GestureRecognizers>
                    <PinchGestureRecognizer PinchUpdated="OnPinchUpdated" />
                </ContentView.GestureRecognizers>
                <GraphicsView x:Name="CanvasView" BackgroundColor="White"
                              StartInteraction="OnCanvasStart" DragInteraction="OnCanvasDrag" EndInteraction="OnCanvasEnd"/>
            </ContentView>
        </Grid>
    </Grid>
</ContentPage>