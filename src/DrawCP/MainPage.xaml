<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:graphics="clr-namespace:DrawCP.Graphics"
             x:Class="DrawCP.MainPage"
             Title="Lucifer Drawing Pro">

    <Grid RowDefinitions="Auto, *">
        <!-- TOOLBAR: Khu vực điều khiển -->
        <ScrollView Grid.Row="0" BackgroundColor="#E1E1E1" VerticalScrollBarVisibility="Never">
            <FlexLayout Wrap="Wrap" Padding="5" JustifyContent="Start" AlignItems="Center">

                <!-- Nhóm 1: Chọn công cụ (Tools) -->
                <Frame Margin="2" Padding="5" CornerRadius="5" BackgroundColor="White">
                    <HorizontalStackLayout Spacing="3">
                        <Button Text="Select" Clicked="OnToolSelected" CommandParameter="Point" WidthRequest="65" HeightRequest="40" FontSize="11" BackgroundColor="#2196F3"/>
                        <Button Text="Line" Clicked="OnToolSelected" CommandParameter="Line" WidthRequest="55" HeightRequest="40" FontSize="11"/>
                        <Button Text="Rect" Clicked="OnToolSelected" CommandParameter="Rectangle" WidthRequest="55" HeightRequest="40" FontSize="11"/>
                        <Button Text="Square" Clicked="OnToolSelected" CommandParameter="Square" WidthRequest="65" HeightRequest="40" FontSize="11"/>
                        <Button Text="Ellipse" Clicked="OnToolSelected" CommandParameter="Ellipse" WidthRequest="65" HeightRequest="40" FontSize="11"/>
                        <Button Text="Circle" Clicked="OnToolSelected" CommandParameter="Circle" WidthRequest="60" HeightRequest="40" FontSize="11"/>
                    </HorizontalStackLayout>
                </Frame>

                <!-- Nhóm 2: Chỉnh sửa (Edit) -->
                <Frame Margin="2" Padding="5" CornerRadius="5" BackgroundColor="White">
                    <HorizontalStackLayout Spacing="3">
                        <Button Text="Fill" Clicked="OnFillShape" WidthRequest="55" HeightRequest="40" FontSize="11" BackgroundColor="#FF9800"/>
                        <Button Text="Undo" Clicked="OnUndo" WidthRequest="55" HeightRequest="40" FontSize="11" BackgroundColor="#607D8B"/>
                        <Button Text="Del" Clicked="OnDelete" WidthRequest="50" HeightRequest="40" FontSize="11" BackgroundColor="#F44336"/>
                    </HorizontalStackLayout>
                </Frame>

                <!-- Nhóm 3: Thuộc tính (Properties) -->
                <Frame Margin="2" Padding="5" CornerRadius="5" BackgroundColor="White">
                    <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                        <Label Text="Size:" VerticalOptions="Center" FontSize="12"/>
                        <Slider x:Name="ThicknessSlider" Minimum="1" Maximum="20" Value="2" WidthRequest="80" ValueChanged="OnThicknessChanged"/>
                        <BoxView x:Name="ColorPreview" Color="Black" WidthRequest="30" HeightRequest="30" CornerRadius="15">
                            <BoxView.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnColorPickerTapped"/>
                            </BoxView.GestureRecognizers>
                        </BoxView>
                    </HorizontalStackLayout>
                </Frame>

                <!-- Nhóm 4: Lưu trữ (File) -->
                <Frame Margin="2" Padding="5" CornerRadius="5" BackgroundColor="White">
                    <HorizontalStackLayout Spacing="3">
                        <Button Text="Import" Clicked="OnLoadBinary" WidthRequest="65" HeightRequest="40" FontSize="11" BackgroundColor="#9E9E9E"/>
                        <Button Text="Save Bin" Clicked="OnSaveBinary" WidthRequest="75" HeightRequest="40" FontSize="11" BackgroundColor="#4CAF50"/>
                        <Button Text="Export PNG" Clicked="OnExportImage" WidthRequest="85" HeightRequest="40" FontSize="11" BackgroundColor="#3F51B5"/>
                    </HorizontalStackLayout>
                </Frame>
            </FlexLayout>
        </ScrollView>

        <!-- Vùng vẽ -->
        <GraphicsView Grid.Row="1" x:Name="CanvasView"
                      StartInteraction="OnCanvasStart"
                      DragInteraction="OnCanvasDrag"
                      EndInteraction="OnCanvasEnd"
                      BackgroundColor="White"/>
    </Grid>
</ContentPage>